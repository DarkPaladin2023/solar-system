<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body>
<%- include('partials/nav') %>

    <h1 class="bg-info text-white p-3" style="margin: 0;">Lab 5: The Solar System</h1>

<div class="container-fluid my-5">
  <% if (planetData){ %>
    <div class="row gy-4">
      <div class="col-md-6">
        <div class="card p-4">
          <h2><%= planetName %></h2>
          <p><strong>Description:</strong> <%= planetData.description || 'N/A' %></p>
          <p><strong>Distance from Sun:</strong> <%= planetData.distanceFromSun || 'N/A' %></p>
          <p><strong>Year Length:</strong> <%= planetData.yearLength || 'N/A' %></p>
          <p><strong>Day Length:</strong> <%= planetData.oneEarthDay || 'N/A' %></p>
          <p><strong>Radius:</strong> <%= planetData.radius || 'N/A' %> km</p>
          <p><strong>Moons:</strong> <%= planetData.moons || 'N/A' %></p>
          <% if (planetData.items && Array.isArray(planetData.items)) { %>
            <div class="mt-3">
              <h5>List of <%= planetName %></h5>
              <ul class="list-group list-group-flush">
                <% planetData.items.forEach(function(item) { %>
                  <li class="list-group-item bg-transparent text-white border-light"><%= item %></li>
                <% }); %>
              </ul>
            </div>
          <% } %>
          <% if (planetData.websiteLink) { %>
            <p><a href="<%= planetData.websiteLink %>" target="_blank" rel="noopener" class="btn btn-primary">View More on NASA</a></p>
          <% } %>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card p-4 text-center">
          <h3>Image</h3>
          <img src="<%= planetData.image %>" alt="<%= planetName %>" class="img-fluid rounded planet-image">
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="alert alert-warning">Planet not found. Please select a planet from the menu.</div>
  <% } %>
</div>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
</body>
</html>